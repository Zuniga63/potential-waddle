APP_NAME=Nest API Template

APP_HOST=localhost
PORT=3000

JWT_SECRET=MySecret
JWT_EXPIRES_IN=1d

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=MyPassword
DB_NAME=NestAPI
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=binntu-project
GOOGLE_CLOUD_KEYFILE={"type":"service_account",...}
GOOGLE_CLOUD_STORAGE_BUCKET=binntu-documents
GOOGLE_CLOUD_STORAGE_BASE_URL=https://storage.googleapis.com
TERMS_ENFORCEMENT_ENABLED=false

# --- MaxMind GeoLite2 (EVENT-03 server-side IP → coarse geo) ---
# Free GeoLite2 account: https://www.maxmind.com/en/geolite2/signup
# Account ID + a generated license key are used by scripts/fetch-geolite.js to
# download GeoLite2-City.mmdb on boot. If unset, geo enrichment fails soft to null.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# Local path the fetch script writes to and GeoIpService reads from (optional override)
GEOLITE_DB_PATH=./geoip/GeoLite2-City.mmdb
